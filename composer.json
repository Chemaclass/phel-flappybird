{
    "name": "chemaclass/phel-flappybird",
    "description": "Flappy Bird in your terminal — a CLI game written in Phel (Lisp on PHP).",
    "type": "project",
    "keywords": [
        "phel",
        "phel-lang",
        "lisp",
        "php",
        "functional",
        "game",
        "flappy-bird",
        "cli",
        "terminal",
        "tui"
    ],
    "homepage": "https://github.com/Chemaclass/phel-flappybird",
    "license": "MIT",
    "authors": [
        {
            "name": "Jose M. Valera Reales",
            "email": "phel@chemaclass.com",
            "homepage": "https://chemaclass.com"
        }
    ],
    "support": {
        "issues": "https://github.com/Chemaclass/phel-flappybird/issues",
        "source": "https://github.com/Chemaclass/phel-flappybird"
    },
    "require": {
        "php": ">=8.4",
        "ext-readline": "*",
        "phel-lang/phel-lang": "^0.44",
        "chemaclass/phel-cli-gui": "^0.11"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "start": [
            "@build",
            "@play"
        ],
        "dev": "vendor/bin/phel run phel-flappybird.main",
        "build": "vendor/bin/phel build --no-cache",
        "play": "php out/main.php",
        "phar": "build/phar.sh",
        "test": "vendor/bin/phel test",
        "format": "vendor/bin/phel format src tests",
        "format-check": "vendor/bin/phel format --dry-run src tests",
        "ci": [
            "@format-check",
            "@test",
            "@build"
        ]
    },
    "scripts-descriptions": {
        "start": "Build then play (compiled entry point)",
        "dev": "Run the game straight from source",
        "build": "Compile Phel to out/",
        "play": "Run the compiled out/main.php",
        "phar": "Build the self-contained PHAR",
        "test": "Run the Phel test suite",
        "format": "Format src and tests",
        "format-check": "Check formatting without writing",
        "ci": "format-check + test + build"
    },
    "config": {
        "preferred-install": "dist",
        "platform": {
            "php": "8.4"
        }
    }
}
